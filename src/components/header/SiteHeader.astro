---
import GithubMark from "./assets/github-mark.svg"

const navItems = [
  { href: "/blog", label: "博客" },
  { href: "/calendar", label: "日程" },
  { href: "/repair", label: "维修" },
  { href: "/nwdc", label: "NWDC" },
  { href: "/lecture", label: "讲座" },
  { href: "/about", label: "关于我们" },
]
---

<header id="site-header">
  <div class="sh-inner">
    <a href="/" class="sh-brand" aria-label="NBTCA home">
      <img src="https://oss.nbtca.space/CA-logo.svg" alt="" width="28" height="28" />
      <span>NBTCA</span>
    </a>

    <nav class="sh-nav" aria-label="Main navigation">
      {navItems.map(item => (
        <a href={item.href} class="sh-nav__link">{item.label}</a>
      ))}
    </nav>

    <div class="sh-actions">
      <a
        href="https://github.com/nbtca"
        target="_blank"
        rel="noopener noreferrer"
        class="sh-github"
        aria-label="GitHub"
      >
        <img src={GithubMark.src} alt="" width="18" height="18" />
      </a>
      <button
        id="sh-menu-btn"
        class="sh-menu-btn"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="sh-mobile-menu"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <rect y="2" width="18" height="1.5" rx="0.75" fill="currentColor" />
          <rect y="8" width="18" height="1.5" rx="0.75" fill="currentColor" />
          <rect y="14" width="18" height="1.5" rx="0.75" fill="currentColor" />
        </svg>
      </button>
    </div>
  </div>

  <nav
    id="sh-mobile-menu"
    class="sh-mobile-menu"
    aria-label="Mobile navigation"
    aria-hidden="true"
  >
    {navItems.map(item => (
      <a href={item.href} class="sh-mobile-menu__link">{item.label}</a>
    ))}
    <a
      href="https://github.com/nbtca"
      target="_blank"
      rel="noopener noreferrer"
      class="sh-mobile-menu__link"
    >GitHub
    </a>
  </nav>
</header>

<script>
  const btn = document.getElementById("sh-menu-btn")
  const menu = document.getElementById("sh-mobile-menu")
  if (btn && menu) {
    btn.addEventListener("click", () => {
      const open = menu.classList.toggle("sh-mobile-menu--open")
      btn.setAttribute("aria-expanded", String(open))
      menu.setAttribute("aria-hidden", String(!open))
    })
  }
</script>

<style>
  /* ── Shell ─────────────────────────────────────────────── */
  #site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .sh-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  /* ── Brand ──────────────────────────────────────────────── */
  .sh-brand {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: #1d1d1f;
    font-size: 15px;
    font-weight: 600;
    flex-shrink: 0;
    transition: opacity 0.15s;
  }
  .sh-brand:hover { opacity: 0.75; }
  .sh-brand img { flex-shrink: 0; }

  /* ── Desktop nav ────────────────────────────────────────── */
  .sh-nav {
    display: none;
    align-items: center;
    gap: 24px;
    flex: 1;
    justify-content: center;
  }
  @media (min-width: 640px) {
    .sh-nav { display: flex; }
  }

  .sh-nav__link {
    font-size: 13px;
    color: #1d1d1f;
    text-decoration: none;
    opacity: 0.75;
    transition: opacity 0.15s;
    white-space: nowrap;
  }
  .sh-nav__link:hover { opacity: 1; }

  /* ── Actions (right side) ───────────────────────────────── */
  .sh-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .sh-github {
    display: flex;
    align-items: center;
    opacity: 0.6;
    transition: opacity 0.15s;
  }
  .sh-github:hover { opacity: 1; }

  .sh-menu-btn {
    display: flex;
    align-items: center;
    background: none;
    border: none;
    cursor: pointer;
    color: #1d1d1f;
    padding: 4px;
    opacity: 0.75;
  }
  .sh-menu-btn:hover { opacity: 1; }
  @media (min-width: 640px) {
    .sh-menu-btn { display: none; }
  }

  /* ── Mobile menu ────────────────────────────────────────── */
  .sh-mobile-menu {
    display: none;
    flex-direction: column;
    background: rgba(255, 255, 255, 0.97);
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    padding: 4px 24px 16px;
  }
  .sh-mobile-menu--open { display: flex; }

  .sh-mobile-menu__link {
    font-size: 15px;
    font-weight: 500;
    color: #1d1d1f;
    text-decoration: none;
    padding: 10px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    transition: color 0.15s;
  }
  .sh-mobile-menu__link:last-child { border-bottom: none; }
  .sh-mobile-menu__link:hover { color: #0071e3; }

  /* ── Dark mode ──────────────────────────────────────────── */
  @media (prefers-color-scheme: dark) {
    #site-header {
      background: rgba(29, 29, 31, 0.8);
      border-bottom-color: rgba(255, 255, 255, 0.08);
    }
    .sh-brand,
    .sh-nav__link,
    .sh-mobile-menu__link { color: #f5f5f7; }
    .sh-github img { filter: invert(1); }
    .sh-menu-btn { color: #f5f5f7; }
    .sh-mobile-menu {
      background: rgba(29, 29, 31, 0.97);
      border-top-color: rgba(255, 255, 255, 0.06);
    }
    .sh-mobile-menu__link {
      border-bottom-color: rgba(255, 255, 255, 0.05);
    }
    .sh-mobile-menu__link:hover { color: #60a5fa; }
  }
</style>
