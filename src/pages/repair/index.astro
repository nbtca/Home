---
import BaseLayout from "../../layouts/BaseLayout.astro"
import RepairHeader from "../../components/header/RepairHeader.astro"
import RepairLandingSection from "./RepairLandingSection.tsx"
---

<BaseLayout>
  <section>
    <RepairHeader />
    <RepairLandingSection client:load />

    <!-- ── Repair Day info ───────────────────────────────── -->
    <div class="rd-info">
      <div class="rd-container">
        <figure class="rd-photo">
          <img
            src="/static/images/homepage/repair.jpg"
            alt="Repair Day on campus"
            loading="lazy"
          />
          <figcaption>理工维修日 · 每月定期举办</figcaption>
        </figure>
        <div class="rd-copy">
          <p class="rd-label">Repair Day</p>
          <h2 class="rd-title">理工维修日</h2>
          <p class="rd-body">
            在接受线上预约之外，我们每月定时定点举办线下维修日，
            带上你的设备，我们现场为你服务。
          </p>
          <p class="rd-body">
            查看<a href="/calendar" class="rd-link">协会活动日历</a>，
            了解下一次维修日的时间与地点。
          </p>
          <a href="/calendar" class="rd-btn">查看活动日历 →</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Font ───────────────────────────────────────────────── */
  :root {
    --rd-font: -apple-system, BlinkMacSystemFont, "SF Pro Display",
      "PingFang SC", "Helvetica Neue", sans-serif;
  }

  /* ── Repair Day info section ────────────────────────────── */
  .rd-info {
    background: #f5f5f7;
    padding: 80px 0 96px;
  }
  .rd-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
  }
  @media (min-width: 768px) {
    .rd-container {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* ── Photo ──────────────────────────────────────────────── */
  .rd-photo {
    margin: 0;
    border-radius: 16px;
    overflow: hidden;
    position: relative;
  }
  .rd-photo img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }
  .rd-photo figcaption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 32px 20px 16px;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.6) 0%,
      transparent 100%
    );
    font-family: var(--rd-font);
    font-size: 13px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.75);
    letter-spacing: 0.02em;
  }

  /* ── Copy ───────────────────────────────────────────────── */
  .rd-label {
    font-family: var(--rd-font);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6e6e73;
    margin: 0 0 12px;
  }
  .rd-title {
    font-family: var(--rd-font);
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: #1d1d1f;
    margin: 0 0 20px;
  }
  .rd-body {
    font-family: var(--rd-font);
    font-size: clamp(15px, 2vw, 17px);
    line-height: 1.7;
    color: #6e6e73;
    margin: 0 0 12px;
  }
  .rd-link {
    color: #0071e3;
    text-decoration: none;
  }
  .rd-link:hover { text-decoration: underline; }
  .rd-btn {
    display: inline-flex;
    align-items: center;
    margin-top: 16px;
    padding: 10px 22px;
    border-radius: 980px;
    background: #1d1d1f;
    color: #f5f5f7;
    font-family: var(--rd-font);
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.2s;
  }
  .rd-btn:hover { background: #2d2d2f; }
</style>
