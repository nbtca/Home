---
import BaseLayout from "../../layouts/BaseLayout.astro"

const sessions = [
  {
    status: "upcoming" as const,
    title: "BaaS — Backend as a Service",
    description: "介绍 Supabase 与 Pocketbase，探索后端即服务的现代实践。",
    tags: ["Supabase", "Pocketbase", "BaaS"],
  },
  {
    status: "past" as const,
    title: "Infrastructure as Code",
    description:
      "通过 Pulumi 和 Cloud-init 自动化管理云资源与虚拟机的创建和配置，实践 IaC 理念。",
    tags: ["Pulumi", "IaC", "Cloud-init"],
  },
  {
    status: "past" as const,
    title: "Minecraft 服务器开设 & 公益算力",
    description:
      "从零搭建 Minecraft 服务器，并探索公益算力资源的申请与实际使用。",
    tags: ["Minecraft", "Server", "Cloud"],
  },
]
---

<BaseLayout primaryTitle="NWDC">

  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="nw-hero">
    <div class="nw-hero__bg">
      <img src="/static/images/nwdc/hero.jpg" alt="" />
      <div class="nw-hero__overlay"></div>
    </div>
    <div class="nw-hero__body">
      <p class="nw-eyebrow">每月两次 · 线上技术分享</p>
      <h1 class="nw-hero__wordmark">NWDC</h1>
      <p class="nw-hero__full-name">
        NingboTech Wide<br />Developer Conference
      </p>
      <p class="nw-hero__desc">
        面向在校学生及毕业从业者<br />
        围绕真实项目与技术实践交流与分享
      </p>
      <div class="nw-hero__actions">
        <a
          href="https://meet.lk.nbtca.space:10086/nwdc"
          target="_blank"
          rel="noopener noreferrer"
          class="nw-btn nw-btn--fill"
        >加入会议室
        </a>
        <a href="/calendar" class="nw-btn nw-btn--ghost">查看活动日历 →</a>
      </div>
    </div>
  </section>

  <!-- ── What is NWDC ──────────────────────────────────────── -->
  <section class="nw-about">
    <div class="nw-container nw-about__grid">
      <div class="nw-about__copy">
        <p class="nw-label">About NWDC</p>
        <h2 class="nw-title">开发者主导的<br />技术分享活动</h2>
        <p class="nw-body">
          NWDC 名称致敬 Apple WWDC，是 NBTCA 定期举办的线上技术分享活动，通常每月两次。
          每期由一位或多位成员围绕真实项目与技术实践进行分享，随后参与者展开自由讨论。
        </p>
        <p class="nw-body">
          活动面向在校学生及已毕业从业者，无论你是在校成员还是校友，
          只要对技术有热情，都欢迎加入。
        </p>
      </div>
      <figure class="nw-about__img">
        <img
          src="/static/images/nwdc/session.jpg"
          alt="NWDC session"
          loading="lazy"
        />
      </figure>
    </div>
  </section>

  <!-- ── Recent sessions ───────────────────────────────────── -->
  <section class="nw-sessions">
    <div class="nw-container">
      <p class="nw-label">Recent Sessions</p>
      <h2 class="nw-title">近期分享</h2>
      <div class="nw-session-grid">
        {sessions.map(s => (
          <article class:list={["nw-session", { "nw-session--upcoming": s.status === "upcoming" }]}>
            <span class="nw-session__badge">
              {s.status === "upcoming" ? "即将到来" : "已结束"}
            </span>
            <h3 class="nw-session__title">{s.title}</h3>
            <p class="nw-session__desc">{s.description}</p>
            <ul class="nw-session__tags">
              {s.tags.map(tag => <li>{tag}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Next event ────────────────────────────────────────── -->
  <section class="nw-next">
    <div class="nw-container">
      <div class="nw-next__card">
        <div class="nw-next__meta">
          <span class="nw-next__badge">线下活动</span>
          <time datetime="2025-04-10">Apr 10 · 20:30 – 22:30</time>
        </div>
        <h2 class="nw-next__title">宁波线下<br />活动策划</h2>
        <p class="nw-next__desc">
          本期主题待定。如果你有希望分享的主题，欢迎发送邮件至
          <a href="mailto:contact@nbtca.space">contact@nbtca.space</a>。
        </p>
        <div class="nw-next__actions">
          <a
            href="https://meet.lk.nbtca.space:10086/nwdc"
            target="_blank"
            rel="noopener noreferrer"
            class="nw-btn nw-btn--fill"
          >加入会议室
          </a>
          <a href="/calendar" class="nw-btn nw-btn--ghost">添加至日历 →</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Font stack ─────────────────────────────────────────── */
  :root {
    --nw-font: -apple-system, BlinkMacSystemFont, "SF Pro Display",
      "PingFang SC", "Helvetica Neue", sans-serif;
  }

  /* ── Shared primitives ──────────────────────────────────── */
  .nw-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .nw-label {
    font-family: var(--nw-font);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    margin: 0 0 12px;
  }

  .nw-title {
    font-family: var(--nw-font);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: #f5f5f7;
    margin: 0 0 24px;
  }

  .nw-body {
    font-family: var(--nw-font);
    font-size: clamp(16px, 2vw, 19px);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0 0 16px;
  }

  .nw-eyebrow {
    font-family: var(--nw-font);
    font-size: 13px;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.5);
    margin: 0 0 20px;
  }

  /* ── Buttons ────────────────────────────────────────────── */
  .nw-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 11px 24px;
    border-radius: 980px;
    font-family: var(--nw-font);
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .nw-btn--fill {
    background: #0071e3;
    color: #fff;
  }
  .nw-btn--fill:hover { background: #0077ed; }
  .nw-btn--ghost {
    color: rgba(255, 255, 255, 0.8);
  }
  .nw-btn--ghost:hover { color: #fff; }

  /* ── Hero ───────────────────────────────────────────────── */
  .nw-hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #050505;
    overflow: hidden;
  }
  .nw-hero__bg {
    position: absolute;
    inset: 0;
  }
  .nw-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.35;
  }
  .nw-hero__overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 80% 60% at 50% 60%,
      transparent 0%,
      rgba(5, 5, 5, 0.7) 100%
    );
  }
  .nw-hero__body {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 24px 24px 48px;
    max-width: 720px;
  }
  .nw-hero__wordmark {
    font-family: var(--nw-font);
    font-size: clamp(80px, 16vw, 160px);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: #fff;
    margin: 0 0 8px;
    line-height: 1;
  }
  .nw-hero__full-name {
    font-family: var(--nw-font);
    font-size: clamp(18px, 2.5vw, 26px);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.55);
    margin: 0 0 24px;
    line-height: 1.4;
    letter-spacing: 0.01em;
  }
  .nw-hero__desc {
    font-family: var(--nw-font);
    font-size: clamp(15px, 2vw, 19px);
    color: rgba(255, 255, 255, 0.8);
    margin: 0 0 40px;
    line-height: 1.6;
  }
  .nw-hero__actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── About ──────────────────────────────────────────────── */
  .nw-about {
    background: #0a0a0a;
    padding: 96px 0;
  }
  .nw-about__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 56px;
    align-items: center;
  }
  @media (min-width: 768px) {
    .nw-about__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .nw-about__img {
    border-radius: 16px;
    overflow: hidden;
    margin: 0;
  }
  .nw-about__img img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  /* ── Sessions ───────────────────────────────────────────── */
  .nw-sessions {
    background: #050505;
    padding: 96px 0;
  }
  .nw-session-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2px;
    margin-top: 40px;
    border-radius: 16px;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .nw-session-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .nw-session {
    background: rgba(255, 255, 255, 0.04);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: background 0.2s;
  }
  .nw-session:hover {
    background: rgba(255, 255, 255, 0.07);
  }
  .nw-session--upcoming {
    background: rgba(0, 113, 227, 0.12);
  }
  .nw-session--upcoming:hover {
    background: rgba(0, 113, 227, 0.15);
  }
  .nw-session__badge {
    font-family: var(--nw-font);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
  }
  .nw-session--upcoming .nw-session__badge {
    color: #60a5fa;
  }
  .nw-session__title {
    font-family: var(--nw-font);
    font-size: clamp(18px, 2.5vw, 22px);
    font-weight: 600;
    color: #f5f5f7;
    margin: 0;
    line-height: 1.3;
  }
  .nw-session__desc {
    font-family: var(--nw-font);
    font-size: 14px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
    flex: 1;
  }
  .nw-session__tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .nw-session__tags li {
    font-family: var(--nw-font);
    font-size: 11px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.4);
    background: rgba(255, 255, 255, 0.07);
    padding: 3px 10px;
    border-radius: 980px;
  }

  /* ── Next event ─────────────────────────────────────────── */
  .nw-next {
    background: #0a0a0a;
    padding: 80px 0 96px;
  }
  .nw-next__card {
    background: rgba(0, 113, 227, 0.08);
    border: 1px solid rgba(0, 113, 227, 0.2);
    border-radius: 24px;
    padding: clamp(32px, 5vw, 64px);
    max-width: 820px;
  }
  .nw-next__meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    font-family: var(--nw-font);
    font-size: 14px;
    color: rgba(255, 255, 255, 0.5);
  }
  .nw-next__badge {
    background: rgba(0, 113, 227, 0.25);
    color: #60a5fa;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 980px;
  }
  .nw-next__title {
    font-family: var(--nw-font);
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: #f5f5f7;
    margin: 0 0 20px;
    line-height: 1.1;
  }
  .nw-next__desc {
    font-family: var(--nw-font);
    font-size: clamp(15px, 2vw, 18px);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0 0 36px;
    max-width: 560px;
  }
  .nw-next__desc a {
    color: #60a5fa;
    text-decoration: none;
  }
  .nw-next__desc a:hover { text-decoration: underline; }
  .nw-next__actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
</style>
