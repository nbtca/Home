---
import BaseLayout from "../layouts/BaseLayout.astro"
import MoreTile from "../layouts/MoreTile.astro"

const allPosts = await Astro.glob("../pages/posts/*.md")
const Blogs = await Astro.glob("../pages/posts/blogs/**/*.md")

allPosts.sort((a, b) => {
  if (
    a.frontmatter.title
    && (a.frontmatter.title as string).startsWith("计算机协会入社指南")
  ) {
    return -99999999999
  }
  return Date.parse(b.frontmatter.pubDate) - Date.parse(a.frontmatter.pubDate)
})

Blogs.sort(
  (a, b) =>
    Date.parse(b.frontmatter.pubDate) - Date.parse(a.frontmatter.pubDate),
)

const latestPosts = [...allPosts.slice(0, 6)]
const galleryImages = [
  { src: "/static/images/homepage/gallery-1.jpg", alt: "欢迎新同学" },
  { src: "/static/images/homepage/gallery-2.jpg", alt: "协作与交流" },
  { src: "/static/images/homepage/gallery-3.jpg", alt: "例会讨论" },
  { src: "/static/images/homepage/gallery-4.jpg", alt: "技术讲座" },
  { src: "/static/images/homepage/gallery-5.jpg", alt: "维修工作" },
  { src: "/static/images/homepage/gallery-6.jpg", alt: "动手实践" },
]
---

<BaseLayout>
  <!-- ═══════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════ -->
  <section class="hp-hero">
    <div class="hp-hero__bg">
      <img
        src="/static/images/homepage/hero.jpg"
        alt="NBTCA 计算机协会成员"
        class="hp-hero__img"
      />
      <div class="hp-hero__overlay"></div>
    </div>
    <div class="hp-hero__content">
      <p class="hp-hero__eyebrow">宁波科技大学计算机协会</p>
      <h1 class="hp-hero__headline">拔电关机</h1>
      <p class="hp-hero__sub">技术 · 创造 · 社区</p>
      <div class="hp-hero__ctas">
        <a href="/about" class="hp-btn hp-btn--primary">了解我们</a>
        <a href="/repair" class="hp-btn hp-btn--ghost">预约维修</a>
      </div>
    </div>
    <a href="#services" class="hp-hero__scroll" aria-label="向下滚动">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </a>
  </section>

  <!-- ═══════════════════════════════════════════════
       SERVICES
  ═══════════════════════════════════════════════ -->
  <section id="services" class="hp-services">
    <div class="hp-container">
      <div class="hp-section-header">
        <h2 class="hp-section-title">我们能做什么</h2>
        <p class="hp-section-sub">专业、开放、充满热情的技术社区</p>
      </div>
      <div class="hp-services__grid">

        <a href="/repair" class="hp-service-card">
          <div class="hp-service-card__media">
            <img src="/static/images/homepage/repair.png" alt="设备维修" />
          </div>
          <div class="hp-service-card__body">
            <span class="hp-service-card__tag">维修</span>
            <h3 class="hp-service-card__title">设备维修</h3>
            <p class="hp-service-card__desc">
              专业团队为你的笔记本、手机提供清灰、换屏、数据恢复等服务，让爱机重获新生。
            </p>
            <span class="hp-service-card__cta">预约维修 →</span>
          </div>
        </a>

        <a href="/calendar" class="hp-service-card">
          <div class="hp-service-card__media">
            <img src="/static/images/homepage/events.jpg" alt="社区活动" />
          </div>
          <div class="hp-service-card__body">
            <span class="hp-service-card__tag">活动</span>
            <h3 class="hp-service-card__title">社区活动</h3>
            <p class="hp-service-card__desc">
              定期组织技术分享、竞赛、户外活动，连接对技术充满热爱的同学，一起成长。
            </p>
            <span class="hp-service-card__cta">查看日历 →</span>
          </div>
        </a>

        <a href="https://docs.nbtca.space" target="_blank" rel="noopener noreferrer" class="hp-service-card">
          <div class="hp-service-card__media">
            <img src="/static/images/homepage/tech.jpg" alt="技术文档" />
          </div>
          <div class="hp-service-card__body">
            <span class="hp-service-card__tag">文档</span>
            <h3 class="hp-service-card__title">技术文档</h3>
            <p class="hp-service-card__desc">
              汇集协会成员整理的技术笔记、教程与知识库，开放共享，持续更新。
            </p>
            <span class="hp-service-card__cta">阅读文档 →</span>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       ACTIVITY HIGHLIGHT (full-bleed feature)
  ═══════════════════════════════════════════════ -->
  <section class="hp-feature">
    <div class="hp-feature__inner">
      <div class="hp-feature__text">
        <p class="hp-feature__eyebrow">维修服务</p>
        <h2 class="hp-feature__title">让技术<br />真正有用</h2>
        <p class="hp-feature__desc">
          协会成员自发组织公益维修，帮助同学解决设备难题。无论是散热清灰、
          系统重装，还是硬件更换，我们用技术回馈校园。
        </p>
        <a href="/repair/create-ticket" class="hp-btn hp-btn--dark">立即预约</a>
      </div>
      <div class="hp-feature__media">
        <img
          src="/static/images/homepage/repair.png"
          alt="设备维修现场"
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       PHOTO GALLERY STRIP
  ═══════════════════════════════════════════════ -->
  <section class="hp-gallery">
    <div class="hp-container">
      <div class="hp-section-header">
        <h2 class="hp-section-title">协会活动</h2>
        <p class="hp-section-sub">记录每一次相遇与成长</p>
      </div>
    </div>
    <div class="hp-gallery__strip">
      {galleryImages.map(img => (
        <div class="hp-gallery__item">
          <img src={img.src} alt={img.alt} loading="lazy" />
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       LATEST ARTICLES  (保留原有博客功能)
  ═══════════════════════════════════════════════ -->
  <section class="hp-articles">
    <div class="hp-container">
      <div class="hp-articles__header">
        <div>
          <h2 class="hp-section-title">最新文章</h2>
          <p class="hp-section-sub">来自协会成员的技术与生活分享</p>
        </div>
        <a href="/blog" class="hp-btn hp-btn--outline">全部文章</a>
      </div>

      <ul role="list" class="hp-articles__grid">
        {
          latestPosts.map(post => (
            <MoreTile
              title={post.frontmatter.title}
              href={post.url}
              date={post.frontmatter.pubDate}
              tags={post.frontmatter.tags}
              cover={post.frontmatter.cover}
            />
          ))
        }
        {
          Blogs.slice(0, 2).map(post => (
            <MoreTile
              title={post.frontmatter.title}
              href={post.url}
              date={post.frontmatter.pubDate}
              tags={post.frontmatter.tags}
              cover={post.frontmatter.cover}
            />
          ))
        }
      </ul>

      <div class="hp-articles__more">
        <a href="/blog" class="hp-btn hp-btn--primary">阅读历史文章</a>
      </div>
    </div>
  </section>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", function () {
      const script = document.createElement("script")
      script.src = "/static/js/animation.js"
      document.head.appendChild(script)
      script.onload = function () {
        initImage()
      }

      // Smooth scroll for hero anchor
      document.querySelectorAll("a[href^=\"#\"]").forEach((anchor) => {
        anchor.addEventListener("click", function (e) {
          e.preventDefault()
          const target = document.querySelector(this.getAttribute("href"))
          if (target) {
            target.scrollIntoView({ behavior: "smooth" })
          }
        })
      })

      // Scroll-in animations
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("hp-visible")
            }
          })
        },
        { threshold: 0.1 },
      )
      document.querySelectorAll(".hp-animate").forEach(el => observer.observe(el))
    })
  </script>
</BaseLayout>

<style>
  /* ─────────────────────────────────────────
     DESIGN TOKENS
  ───────────────────────────────────────── */
  :root {
    --hp-font: -apple-system, BlinkMacSystemFont, "SF Pro Display",
      "PingFang SC", "Helvetica Neue", sans-serif;
    --hp-black: #1d1d1f;
    --hp-gray: #6e6e73;
    --hp-bg: #f5f5f7;
    --hp-blue: #0071e3;
    --hp-blue-hover: #0077ed;
    --hp-radius: 20px;
    --hp-radius-sm: 12px;
    --hp-max: 1200px;
    --hp-transition: 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* ─────────────────────────────────────────
     SHARED UTILITIES
  ───────────────────────────────────────── */
  .hp-container {
    max-width: var(--hp-max);
    margin: 0 auto;
    padding: 0 24px;
  }

  .hp-section-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .hp-section-title {
    font-family: var(--hp-font);
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--hp-black);
    margin: 0 0 12px;
  }

  .hp-section-sub {
    font-family: var(--hp-font);
    font-size: 17px;
    color: var(--hp-gray);
    margin: 0;
  }

  /* Buttons */
  .hp-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 28px;
    border-radius: 980px;
    font-family: var(--hp-font);
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    transition: all var(--hp-transition);
    white-space: nowrap;
  }

  .hp-btn--primary {
    background: var(--hp-blue);
    color: #fff;
  }
  .hp-btn--primary:hover {
    background: var(--hp-blue-hover);
  }

  .hp-btn--ghost {
    background: rgba(255, 255, 255, 0.18);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(10px);
  }
  .hp-btn--ghost:hover {
    background: rgba(255, 255, 255, 0.28);
  }

  .hp-btn--dark {
    background: var(--hp-black);
    color: #fff;
  }
  .hp-btn--dark:hover {
    background: #000;
  }

  .hp-btn--outline {
    background: transparent;
    color: var(--hp-blue);
    border: 1px solid var(--hp-blue);
    padding: 10px 22px;
    font-size: 14px;
  }
  .hp-btn--outline:hover {
    background: var(--hp-blue);
    color: #fff;
  }

  /* ─────────────────────────────────────────
     HERO
  ───────────────────────────────────────── */
  .hp-hero {
    position: relative;
    height: 92vh;
    min-height: 560px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #000;
  }

  .hp-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hp-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    filter: brightness(0.55);
  }

  .hp-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.2) 0%,
      rgba(0, 0, 0, 0.1) 50%,
      rgba(0, 0, 0, 0.55) 100%
    );
  }

  .hp-hero__content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 0 24px;
    max-width: 800px;
  }

  .hp-hero__eyebrow {
    font-family: var(--hp-font);
    font-size: clamp(13px, 1.5vw, 16px);
    font-weight: 400;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.8);
    text-transform: uppercase;
    margin: 0 0 20px;
  }

  .hp-hero__headline {
    font-family: var(--hp-font);
    font-size: clamp(52px, 9vw, 96px);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #fff;
    margin: 0 0 16px;
    line-height: 1.05;
  }

  .hp-hero__sub {
    font-family: var(--hp-font);
    font-size: clamp(18px, 2.5vw, 24px);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.85);
    margin: 0 0 40px;
    letter-spacing: 0.05em;
  }

  .hp-hero__ctas {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hp-hero__scroll {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    color: rgba(255, 255, 255, 0.7);
    animation: bounce 2s ease-in-out infinite;
    text-decoration: none;
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  /* ─────────────────────────────────────────
     SERVICES
  ───────────────────────────────────────── */
  .hp-services {
    padding: 120px 0;
    background: #fff;
  }

  .hp-services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  @media (max-width: 900px) {
    .hp-services__grid {
      grid-template-columns: 1fr;
    }
  }

  .hp-service-card {
    display: flex;
    flex-direction: column;
    background: var(--hp-bg);
    border-radius: var(--hp-radius);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform var(--hp-transition), box-shadow var(--hp-transition);
  }

  .hp-service-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.12);
  }

  .hp-service-card__media {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .hp-service-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--hp-transition);
  }

  .hp-service-card:hover .hp-service-card__media img {
    transform: scale(1.04);
  }

  .hp-service-card__body {
    padding: 28px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .hp-service-card__tag {
    font-family: var(--hp-font);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--hp-blue);
    margin-bottom: 10px;
  }

  .hp-service-card__title {
    font-family: var(--hp-font);
    font-size: 22px;
    font-weight: 700;
    color: var(--hp-black);
    margin: 0 0 12px;
    letter-spacing: -0.01em;
  }

  .hp-service-card__desc {
    font-family: var(--hp-font);
    font-size: 15px;
    line-height: 1.6;
    color: var(--hp-gray);
    margin: 0 0 20px;
    flex: 1;
  }

  .hp-service-card__cta {
    font-family: var(--hp-font);
    font-size: 15px;
    font-weight: 500;
    color: var(--hp-blue);
    transition: gap var(--hp-transition);
  }

  /* ─────────────────────────────────────────
     FEATURE (full-bleed highlight)
  ───────────────────────────────────────── */
  .hp-feature {
    background: var(--hp-black);
    padding: 100px 24px;
    overflow: hidden;
  }

  .hp-feature__inner {
    max-width: var(--hp-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  @media (max-width: 768px) {
    .hp-feature__inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .hp-feature__media {
      order: -1;
    }
  }

  .hp-feature__eyebrow {
    font-family: var(--hp-font);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--hp-blue);
    margin: 0 0 16px;
  }

  .hp-feature__title {
    font-family: var(--hp-font);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #fff;
    margin: 0 0 24px;
    line-height: 1.1;
  }

  .hp-feature__desc {
    font-family: var(--hp-font);
    font-size: 17px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0 0 36px;
  }

  .hp-feature__media {
    border-radius: var(--hp-radius);
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .hp-feature__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ─────────────────────────────────────────
     GALLERY STRIP
  ───────────────────────────────────────── */
  .hp-gallery {
    padding: 100px 0;
    background: #fff;
    overflow: hidden;
  }

  .hp-gallery__strip {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    padding: 0 24px;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .hp-gallery__strip::-webkit-scrollbar {
    display: none;
  }

  .hp-gallery__item {
    flex: 0 0 auto;
    width: min(340px, 75vw);
    aspect-ratio: 4 / 3;
    border-radius: var(--hp-radius-sm);
    overflow: hidden;
    scroll-snap-align: start;
  }

  .hp-gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--hp-transition);
  }

  .hp-gallery__item:hover img {
    transform: scale(1.04);
  }

  /* ─────────────────────────────────────────
     ARTICLES
  ───────────────────────────────────────── */
  .hp-articles {
    padding: 100px 0 120px;
    background: var(--hp-bg);
  }

  .hp-articles__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 48px;
    gap: 16px;
    flex-wrap: wrap;
  }

  .hp-articles__header .hp-section-title,
  .hp-articles__header .hp-section-sub {
    text-align: left;
  }

  .hp-articles__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  @media (max-width: 734px) {
    .hp-articles__grid {
      grid-template-columns: 1fr;
    }
    .hp-articles__header {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  .hp-articles__more {
    margin-top: 48px;
    text-align: center;
  }

  /* ─────────────────────────────────────────
     DARK MODE
  ───────────────────────────────────────── */
  body.theme-dark .hp-services,
  body.theme-dark .hp-gallery {
    background: #000;
  }

  body.theme-dark .hp-section-title {
    color: #f5f5f7;
  }

  body.theme-dark .hp-service-card {
    background: #1c1c1e;
  }

  body.theme-dark .hp-service-card__title {
    color: #f5f5f7;
  }

  body.theme-dark .hp-articles {
    background: #111;
  }

  body.theme-dark .hp-section-title {
    color: #f5f5f7;
  }
</style>
