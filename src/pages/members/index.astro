---
import BaseLayout from "../../layouts/BaseLayout.astro"
import MembersList from "./MembersList.tsx"
---

<BaseLayout primaryTitle="成员">
  <section class="mem-section">
    <div class="mem-header">
      <div class="mem-container">
        <p class="mem-label">Members</p>
        <h1 class="mem-title">协会成员</h1>
        <p class="mem-desc">NBTCA 历届在册成员名单</p>
      </div>
    </div>
    <div class="mem-container mem-list-wrap">
      <MembersList client:load />
    </div>
  </section>
</BaseLayout>

<style>
  :root {
    --mem-font: -apple-system, BlinkMacSystemFont, "SF Pro Display",
      "PingFang SC", "Helvetica Neue", sans-serif;
  }

  .mem-section {
    background: #f5f5f7;
    min-height: 60vh;
    padding-bottom: 96px;
  }

  .mem-header {
    background: #1d1d1f;
    padding: 64px 0 56px;
  }

  .mem-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .mem-label {
    font-family: var(--mem-font);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    margin: 0 0 12px;
  }

  .mem-title {
    font-family: var(--mem-font);
    font-size: clamp(40px, 7vw, 72px);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.05;
    color: #f5f5f7;
    margin: 0 0 16px;
  }

  .mem-desc {
    font-family: var(--mem-font);
    font-size: 17px;
    color: rgba(255, 255, 255, 0.5);
    margin: 0;
  }

  .mem-list-wrap {
    padding-top: 40px;
  }

  /* ── Global styles for MembersList component ────────────── */
  :global(.navigate) {
    transition: transform 0.2s;
  }
  :global(.navigate:hover) {
    text-decoration: underline;
    transform: scale(1.1);
  }
  :global(.navigate:active) {
    animation: ease-in-out 1s exit forwards;
  }
  @keyframes exit {
    0% { transform: scale(1.05); }
    100% { transform: scale(1); }
  }
  :global(.no-link-color) {
    color: inherit;
    text-decoration: none;
  }
</style>
