---
import BaseLayout from "../../layouts/BaseLayout.astro"

const activities = [
  {
    label: "Repair Day",
    title: "理工维修日",
    description:
      "每月定期举办，为在校学生提供免费的电脑维修与硬件咨询服务。从清灰散热到系统重装，我们都能帮你搞定。",
    href: "/repair",
    linkLabel: "了解维修日",
    img: "/static/images/homepage/repair.jpg",
    alt: "Repair Day on campus",
  },
  {
    label: "NWDC",
    title: "NingboTech Wide\nDeveloper Conference",
    description:
      "每月两次的线上技术分享活动。由成员围绕真实项目与技术实践进行分享，随后展开自由讨论，面向在校学生及校友开放。",
    href: "/nwdc",
    linkLabel: "了解 NWDC",
    img: "/static/images/homepage/nwdc.jpg",
    alt: "NWDC online session",
  },
  {
    label: "Lecture",
    title: "技术讲座",
    description:
      "每学期 1–2 次的线下学术交流活动。邀请在校成员与校友嘉宾，围绕计算机应用与技术实践进行深度分享，面向全校开放。",
    href: "/lecture",
    linkLabel: "了解讲座",
    img: "/static/images/homepage/lecture.jpg",
    alt: "NBTCA technical lecture",
  },
]

const stats = [
  { value: "7+", label: "年" },
  { value: "100+", label: "届成员" },
  { value: "10+", label: "开源项目" },
]
---

<BaseLayout primaryTitle="关于">

  <!-- ── Hero ──────────────────────────────────────────────── -->
  <section class="ab-hero">
    <div class="ab-hero__body">
      <p class="ab-eyebrow">About NBTCA</p>
      <img
        src="https://oss.nbtca.space/CA-logo.svg"
        alt="NBTCA"
        class="ab-hero__logo"
      />
      <h1 class="ab-hero__title">
        由学生主导的<br />技术社区
      </h1>
      <p class="ab-hero__desc">
        NBTCA 是宁波工程学院计算机协会。<br />
        无论你是在校学生还是校友，只要对技术有热情，这里都欢迎你。
      </p>
    </div>
  </section>

  <!-- ── Mission ───────────────────────────────────────────── -->
  <section class="ab-mission">
    <div class="ab-container ab-mission__grid">
      <div class="ab-mission__copy">
        <p class="ab-label ab-label--dark">Our Mission</p>
        <h2 class="ab-title ab-title--dark">
          推动技术交流，<br />连接不同时代的工程师
        </h2>
        <p class="ab-body ab-body--dark">
          NBTCA 成立至今，始终致力于在校内营造真实的技术氛围——不是课堂上的考试，
          而是动手做项目、分享踩坑经验、互相学习成长。
        </p>
        <p class="ab-body ab-body--dark">
          我们连接了不同专业、不同届别的人。在校成员与已毕业从业者在这里共同交流，
          让技术经验得以传承与积累。
        </p>
      </div>
      <ul class="ab-stats">
        {stats.map(s => (
          <li class="ab-stat">
            <span class="ab-stat__value">{s.value}</span>
            <span class="ab-stat__label">{s.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── Activities ────────────────────────────────────────── -->
  <section class="ab-activities">
    <div class="ab-container">
      <p class="ab-label">What We Do</p>
      <h2 class="ab-title">我们的活动</h2>
    </div>
    <div class="ab-activity-list">
      {activities.map((a, i) => (
        <article class:list={["ab-activity", { "ab-activity--flip": i % 2 === 1 }]}>
          <figure class="ab-activity__img">
            <img src={a.img} alt={a.alt} loading="lazy" />
          </figure>
          <div class="ab-activity__body">
            <p class="ab-activity__label">{a.label}</p>
            <h3 class="ab-activity__title">{a.title}</h3>
            <p class="ab-activity__desc">{a.description}</p>
            <a href={a.href} class="ab-activity__link">{a.linkLabel} →</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ── Open source ───────────────────────────────────────── -->
  <section class="ab-oss">
    <div class="ab-container ab-oss__inner">
      <div class="ab-oss__copy">
        <p class="ab-label ab-label--dark">Open Source</p>
        <h2 class="ab-title ab-title--dark">我们在 GitHub 上开源</h2>
        <p class="ab-body ab-body--dark">
          NBTCA 的大多数项目在 GitHub 上公开维护，包括这个网站本身。
          欢迎提交 PR、报告 Issue，或直接 Fork 来学习和改进。
        </p>
        <a
          href="https://github.com/nbtca"
          target="_blank"
          rel="noopener noreferrer"
          class="ab-btn ab-btn--primary"
        >访问 GitHub →
        </a>
      </div>
      <div class="ab-oss__img">
        <img
          src="/static/images/homepage/tech.jpg"
          alt="Code on screen"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- ── Join CTA ──────────────────────────────────────────── -->
  <section class="ab-join">
    <div class="ab-container">
      <p class="ab-eyebrow">Get Involved</p>
      <h2 class="ab-join__title">和我们一起</h2>
      <p class="ab-join__desc">
        无论你想加入协会、参与活动，还是预约维修，我们都在这里。
      </p>
      <div class="ab-join__actions">
        <a href="/join-us" class="ab-btn ab-btn--fill">加入我们</a>
        <a href="/members" class="ab-btn ab-btn--ghost">查看历届成员 →</a>
        <a href="/repair" class="ab-btn ab-btn--ghost">预约维修 →</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Font ───────────────────────────────────────────────── */
  :root {
    --ab-font: -apple-system, BlinkMacSystemFont, "SF Pro Display",
      "PingFang SC", "Helvetica Neue", sans-serif;
  }

  /* ── Container ──────────────────────────────────────────── */
  .ab-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Shared typography ──────────────────────────────────── */
  .ab-label {
    font-family: var(--ab-font);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    margin: 0 0 12px;
  }
  .ab-label--dark { color: #6e6e73; }

  .ab-title {
    font-family: var(--ab-font);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: #f5f5f7;
    margin: 0 0 24px;
  }
  .ab-title--dark { color: #1d1d1f; }

  .ab-body {
    font-family: var(--ab-font);
    font-size: clamp(16px, 2vw, 18px);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.65);
    margin: 0 0 16px;
  }
  .ab-body--dark { color: #6e6e73; }

  .ab-eyebrow {
    font-family: var(--ab-font);
    font-size: 13px;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.5);
    margin: 0 0 20px;
  }

  /* ── Buttons ────────────────────────────────────────────── */
  .ab-btn {
    display: inline-flex;
    align-items: center;
    padding: 11px 24px;
    border-radius: 980px;
    font-family: var(--ab-font);
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .ab-btn--fill {
    background: #0071e3;
    color: #fff;
  }
  .ab-btn--fill:hover { background: #0077ed; }
  .ab-btn--primary {
    background: #1d1d1f;
    color: #f5f5f7;
  }
  .ab-btn--primary:hover { background: #2d2d2f; }
  .ab-btn--ghost {
    color: rgba(255, 255, 255, 0.8);
  }
  .ab-btn--ghost:hover { color: #fff; }

  /* ── Hero ───────────────────────────────────────────────── */
  .ab-hero {
    background: #050505;
    padding: 120px 24px 96px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .ab-hero__body {
    max-width: 720px;
  }
  .ab-hero__logo {
    width: 72px;
    height: 72px;
    margin: 0 auto 32px;
    display: block;
  }
  .ab-hero__title {
    font-family: var(--ab-font);
    font-size: clamp(48px, 9vw, 96px);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.05;
    color: #f5f5f7;
    margin: 0 0 24px;
  }
  .ab-hero__desc {
    font-family: var(--ab-font);
    font-size: clamp(16px, 2.5vw, 21px);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  /* ── Mission ────────────────────────────────────────────── */
  .ab-mission {
    background: #fff;
    padding: 96px 0;
  }
  .ab-mission__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 56px;
    align-items: start;
  }
  @media (min-width: 768px) {
    .ab-mission__grid {
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }
  }

  /* ── Stats ──────────────────────────────────────────────── */
  .ab-stats {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }
  .ab-stat {
    display: flex;
    align-items: baseline;
    gap: 12px;
    padding: 28px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }
  .ab-stat__value {
    font-family: var(--ab-font);
    font-size: clamp(48px, 7vw, 72px);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: #1d1d1f;
    line-height: 1;
  }
  .ab-stat__label {
    font-family: var(--ab-font);
    font-size: clamp(16px, 2vw, 20px);
    font-weight: 400;
    color: #6e6e73;
  }

  /* ── Activities ─────────────────────────────────────────── */
  .ab-activities {
    background: #0a0a0a;
    padding: 96px 0 80px;
  }
  .ab-activity-list {
    margin-top: 48px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .ab-activity {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 480px;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .ab-activity {
      grid-template-columns: 1fr 1fr;
    }
    .ab-activity--flip .ab-activity__img { order: 2; }
    .ab-activity--flip .ab-activity__body { order: 1; }
  }
  .ab-activity__img {
    margin: 0;
    overflow: hidden;
  }
  .ab-activity__img img {
    width: 100%;
    height: 100%;
    min-height: 280px;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .ab-activity:hover .ab-activity__img img { transform: scale(1.03); }
  .ab-activity__body {
    background: #111;
    padding: clamp(40px, 5vw, 72px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 16px;
  }
  .ab-activity__label {
    font-family: var(--ab-font);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    margin: 0;
  }
  .ab-activity__title {
    font-family: var(--ab-font);
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.15;
    color: #f5f5f7;
    margin: 0;
    white-space: pre-line;
  }
  .ab-activity__desc {
    font-family: var(--ab-font);
    font-size: clamp(15px, 1.8vw, 17px);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
    max-width: 480px;
  }
  .ab-activity__link {
    font-family: var(--ab-font);
    font-size: 15px;
    font-weight: 500;
    color: #60a5fa;
    text-decoration: none;
    transition: opacity 0.2s;
    align-self: flex-start;
  }
  .ab-activity__link:hover { opacity: 0.75; }

  /* ── Open source ────────────────────────────────────────── */
  .ab-oss {
    background: #f5f5f7;
    padding: 96px 0;
  }
  .ab-oss__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 56px;
    align-items: center;
  }
  @media (min-width: 768px) {
    .ab-oss__inner {
      grid-template-columns: 1fr 1fr;
    }
  }
  .ab-oss__img {
    border-radius: 16px;
    overflow: hidden;
  }
  .ab-oss__img img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  /* ── Join CTA ───────────────────────────────────────────── */
  .ab-join {
    background: #050505;
    padding: 96px 0;
    text-align: center;
  }
  .ab-join__title {
    font-family: var(--ab-font);
    font-size: clamp(48px, 8vw, 88px);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.05;
    color: #f5f5f7;
    margin: 0 0 20px;
  }
  .ab-join__desc {
    font-family: var(--ab-font);
    font-size: clamp(16px, 2vw, 19px);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0 auto 40px;
    max-width: 500px;
  }
  .ab-join__actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
